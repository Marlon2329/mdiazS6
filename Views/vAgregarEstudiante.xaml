<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="mdiazS6.Views.vAgregarEstudiante"
             Title="vAgregarEstudiante">
    <VerticalStackLayout Padding="15" Spacing="15">
        <Label 
        Text="AGREGAR ESTUDIANTE"
        VerticalOptions="Center" 
        HorizontalOptions="Center" />

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Label Text="Nombre:" FontSize="18" Grid.Row="0" Grid.Column="0" VerticalOptions="Center" HorizontalOptions="Center" />

            <Entry x:Name="txtNombre" Placeholder="Ingrese el nombre" Grid.Row="0" Grid.Column="1" />

            <Label Text="Apellido:" FontSize="18" Grid.Row="1" Grid.Column="0" VerticalOptions="Center" HorizontalOptions="Center" />

            <Entry x:Name="txtApellido" Placeholder="Ingrese el apellido" Grid.Row="1" Grid.Column="1" />

            <Label Text="Edad:" FontSize="18" Grid.Row="2" Grid.Column="0" VerticalOptions="Center" HorizontalOptions="Center" />

            <Entry x:Name="txtEdad" Placeholder="Ingrese la edad" Grid.Row="2" Grid.Column="1" />

        </Grid>

        <Button x:Name="btnAgregarEstudiante" Text="Agregar" Clicked="btnAgregar_Clicked"  />
    </VerticalStackLayout>
</ContentPage>